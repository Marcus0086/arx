{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "store:allow-load",
    "store:allow-set",
    "store:allow-get",
    "store:allow-save",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "/Volumes/**" }, { "path": "$TEMP/**" }]
    }
  ]
}
